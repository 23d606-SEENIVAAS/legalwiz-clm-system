# Pydantic Models (matching your party_table.py schema)
class PartyRole(str, Enum):
    PARTY_A = "party_a"
    PARTY_B = "party_b"
    PARTY_C = "party_c"
    WITNESS_1 = "witness_1"
    WITNESS_2 = "witness_2"

class CreateParty(BaseModel):
